# Root-level defaults for local development.
PAPER_HARNESS_ENVIRONMENT=development
PAPER_HARNESS_DATA_DIR=./data

# LLM provider defaults.
# Keep "none" for deterministic local/test behavior.
PAPER_HARNESS_LLM_PROVIDER=none

# GLM coding plan example:
# PAPER_HARNESS_LLM_PROVIDER=glm_coding
# PAPER_HARNESS_LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# PAPER_HARNESS_LLM_MODEL=glm-5.1
# PAPER_HARNESS_LLM_API_KEY_ENV=ZAI_API_KEY
# ZAI_API_KEY=your_glm_api_key

# Generic OpenAI-compatible example:
# PAPER_HARNESS_LLM_PROVIDER=openai_compatible
# PAPER_HARNESS_LLM_BASE_URL=https://provider.example.com/v1
# PAPER_HARNESS_LLM_MODEL=provider-model-name
# PAPER_HARNESS_LLM_API_KEY_ENV=PROVIDER_API_KEY
# PROVIDER_API_KEY=your_provider_api_key

# Direct provider examples:
# PAPER_HARNESS_LLM_PROVIDER=anthropic
# PAPER_HARNESS_LLM_MODEL=claude-sonnet-4-5
# ANTHROPIC_API_KEY=your_anthropic_api_key
#
# PAPER_HARNESS_LLM_PROVIDER=gemini
# PAPER_HARNESS_LLM_MODEL=gemini-2.5-pro
# GEMINI_API_KEY=your_gemini_api_key
